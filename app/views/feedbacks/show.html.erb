<% content_for(:title, @feedback) %>

<%= turbo_stream_from(@feedback) %>

<% if @feedback.id.present? %>
  <div class="p">
    <div class="text-gray-600"><%= t(".id") %></div>
    <div class="font-bold"><%= @feedback.id %></div>
  </div>
<% end %>

<% if @feedback.user.present? %>
  <div class="p">
    <div class="text-gray-600"><%= t(".user") %></div>
    <%= render("shared/user", user: @feedback.user) %>
  </div>
<% end %>

<% if @feedback.guest.present? %>
  <div class="p">
    <div class="text-gray-600"><%= t(".guest") %></div>
    <div class="font-bold"><%= @feedback.guest %></div>
  </div>
<% end %>

<% if @feedback.locale.present? %>
  <div class="p">
    <div class="text-gray-600"><%= t(".locale") %></div>
    <div class="font-bold"><%= @feedback.locale %></div>
  </div>
<% end %>

<% if @feedback.path.present? %>
  <div class="p">
    <div class="text-gray-600"><%= t(".path") %></div>
    <div class="font-bold"><%= @feedback.path %></div>
  </div>
<% end %>

<% if @feedback.ip.present? %>
  <div class="p">
    <div class="text-gray-600"><%= t(".ip") %></div>
    <div class="font-bold"><%= @feedback.ip %></div>
  </div>
<% end %>

<% if @feedback.user_agent.present? %>
  <div class="p">
    <div class="text-gray-600"><%= t(".user_agent") %></div>
    <div class="font-bold"><%= @feedback.user_agent %></div>
  </div>
<% end %>

<% if @feedback.message.present? %>
  <div class="p">
    <div class="text-gray-600"><%= t(".message") %></div>
    <div class="font-bold whitespace-pre-wrap"><%= @feedback.message %></div>
  </div>
<% end %>

<% if @feedback.updated_at.present? %>
  <div class="p">
    <div class="text-gray-600"><%= t(".updated_at") %></div>
    <div class="font-bold">
      <%= local_time(@feedback.updated_at, format: :default) %>
    </div>
  </div>
<% end %>

<% if @feedback.created_at.present? %>
  <div class="p">
    <div class="text-gray-600"><%= t(".created_at") %></div>
    <div class="font-bold">
      <%= local_time(@feedback.created_at, format: :default) %>
    </div>
  </div>
<% end %>

<div class="p p--flex">
  <%= link_to(t(".edit"), edit_url, class: :link) %>
  <%= render("shared/confirm", text: t(".destroy"), url: destroy_url) %>
  <%= render("shared/confirm", text: t(".delete"), url: delete_url) %>
</div>
