<% if admin? %>
  <% if @class %>
    <%= code_highlight(@class, class: "p") %>
  <% end %>
  <% if @message %>
    <%= code_highlight(@message, class: "p") %>
  <% end %>
  <% if @app_backtrace %>
    <%= code_highlight(@app_backtrace, class: "p") %>
  <% end %>
  <% if @backtrace %>
    <%= code_highlight(@backtrace, class: "p") %>
  <% end %>
<% end %>
