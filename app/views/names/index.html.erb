<%= turbo_stream_from(@names) %>

<% if can?(:create, Name) %>
  <div class="p"><%= link_to(t(".new"), new_url, class: "button") %></div>
<% end %>

<%= render("shared/search") %>

<turbo-frame id="search" target="_top">
  <% if @names.any? %>
    <div class="p p--flex">
      <%= render("shared/confirm", url: destroy_all_url, text: t(".destroy_all")) %>
      <%= render("shared/confirm", url: delete_all_url, text: t(".delete_all")) %>
    </div>
  <% end %>

  <%= render_collection(partial: "names/name", collection: @names, as: :name) %>
</turbo-frame>
